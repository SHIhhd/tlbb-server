#start or stop ShareMemory1
#!/bin/sh
# Usage: shm start stop clear disp

userage()
{
  echo "Usage: ./shm start|stop|clear|disp"
}

clrsm()
{
  _sharemem=`ps -A | grep ShareMemory1 | awk '{print $4}'`
  if [ "$_sharemem" == "ShareMemory1" ] ; then
    echo "ShareMemory1 already run, stop it first!"
  else
    ipcs > /tmp/tmp$$
    if test -e /tmp/tmp$$
    then
      _runflag=0
      while read _line
      do
        if [ "$_line" == "" ]; then
          continue
        fi

        _run=`echo $_line | grep "Shared Memory Segments"`
        if [ "$_run" != "" ]; then
          _runflag=1
          continue
        fi

        _run=`echo $_line | grep "Semaphore Arrays"`
        if [ "$_run" != "" ]; then
          break
        fi

        _tag=`echo $_line | grep "^0x" | awk '{print $5}'`
        if [ "$_tag" == "" ]; then
          continue
        fi
        if [ "$_tag" == "404" ]; then
          continue
        fi
        _tag=`echo $_line | awk '{print $2}'`
        ./smtool $_tag
      done < /tmp/tmp$$
      return 0
    else
      echo "can't create /tmp/tmp$$, please retry!"
    fi
  fi
  return 1
}

start()
{
  _sharemem=`ps -A | grep ShareMemory1 | awk '{print $4}'`
  if [ "$_sharemem" == "ShareMemory1" ] ; then
    echo "ShareMemory1 already run, start faild!"
  else
    echo 2147483648 > /proc/sys/kernel/shmmax
	unset LD_PRELOAD
	export LD_PRELOAD="/home/tlbb/Server/libNewShareMemory.so"
    ./ShareMemory1&
	unset LD_PRELOAD
    return 0
  fi
  return 1
}

stop()
{
  _sharemem=`ps -A | grep ShareMemory1 | awk '{print $1}'`
  if [ "$_sharemem" == "" ] ; then
    echo "ShareMemory1 not run, stop ok!"
    return 0
  else
    kill -9 $_sharemem
    return 0
  fi
  return 1
}

disp()
{
  _sharemem=`ps -A | grep ShareMemory1 | awk '{print $4}'`
  if [ "$_sharemem" == "ShareMemory1" ] ; then
    echo "ShareMemory1 run ok!!"
    echo ""
    ipcs
  else
    echo "ShareMemory1 not run!"
    return 1
  fi
  return 0
}

if [ $# != 1 ]
then
	userage
	exit 1
fi

case $1 in
	start)
	  clrsm
	  start
		if [ $? == 0 ]; then
		  echo "start ShareMemory1 ok! pls wait for it run in loop()..."
		else
		  echo "some error occ when start ShareMemory1, please retry!"
		fi
	;;
	stop)
	  stop
		if [ $? == 0 ]; then
		  echo "stop shm ok!"
		else
		  echo "some error occ when stop shm, please retry!"
		fi
	;;
	clear)
		clrsm
		if [ $? == 0 ]; then
		  echo "clear shm ok!"
		else
		  echo "some error occ when clear shm, please retry!"
		fi
	;;
	disp)
	  disp
	;;
	*)
		userage
		exit 1
	;;
esac
